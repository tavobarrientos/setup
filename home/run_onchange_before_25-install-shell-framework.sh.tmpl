#!/usr/bin/env bash
{{- if eq .chezmoi.os "windows" }}
# Oh My Posh on Windows is installed by install.ps1 / winget; nothing to do here.
exit 0
{{- end }}

set -euo pipefail
log() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }

{{ if eq .chezmoi.os "linux" -}}
if ! command -v zsh >/dev/null 2>&1; then
  log "Installing zsh"
  sudo apt-get install -y zsh
fi
{{ end -}}

ZSH_DIR="${ZSH:-$HOME/.oh-my-zsh}"
if [ ! -d "$ZSH_DIR" ]; then
  log "Installing Oh My Zsh"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
else
  log "Oh My Zsh already installed"
fi

# Common community plugins
ZSH_CUSTOM="${ZSH_CUSTOM:-$ZSH_DIR/custom}"
[ -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ] || \
  git clone --depth=1 https://github.com/zsh-users/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
[ -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ] || \
  git clone --depth=1 https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"

# --- Powerlevel10k --------------------------------------------------------
# Goal: $ZSH_CUSTOM/themes/powerlevel10k/powerlevel10k.zsh-theme must resolve
# so dot_zshrc can use ZSH_THEME="powerlevel10k/powerlevel10k" uniformly.
P10K_DIR="$ZSH_CUSTOM/themes/powerlevel10k"
if [ -e "$P10K_DIR" ] || [ -L "$P10K_DIR" ]; then
  log "Powerlevel10k already wired up at $P10K_DIR"
else
{{ if eq .chezmoi.os "darwin" -}}
  # macOS: powerlevel10k comes from the romkatv/powerlevel10k Homebrew tap.
  BREW_PREFIX=$(brew --prefix 2>/dev/null)
  BREW_P10K="$BREW_PREFIX/share/powerlevel10k"
  if [ -d "$BREW_P10K" ]; then
    log "Linking Homebrew powerlevel10k into Oh My Zsh custom themes"
    mkdir -p "$ZSH_CUSTOM/themes"
    ln -s "$BREW_P10K" "$P10K_DIR"
  else
    log "Brew powerlevel10k not found at $BREW_P10K; cloning instead"
    git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$P10K_DIR"
  fi
{{ else -}}
  log "Cloning powerlevel10k for Oh My Zsh"
  mkdir -p "$ZSH_CUSTOM/themes"
  git clone --depth=1 https://github.com/romkatv/powerlevel10k.git "$P10K_DIR"
{{ end -}}
fi

# Make zsh the login shell (skip if already, or if zsh isn't in /etc/shells)
if [ "$(basename "${SHELL:-}")" != "zsh" ] && command -v zsh >/dev/null 2>&1; then
  ZSH_PATH=$(command -v zsh)
  if ! grep -qx "$ZSH_PATH" /etc/shells; then
    echo "$ZSH_PATH" | sudo tee -a /etc/shells >/dev/null
  fi
  log "Changing default shell to $ZSH_PATH (you may be prompted for your password)"
  chsh -s "$ZSH_PATH" "$USER" || log "chsh failed; run 'chsh -s $ZSH_PATH' manually."
fi
