#!/usr/bin/env bash
{{- if eq .chezmoi.os "windows" }}
# Windows installs runtimes via winget (see install.ps1 + winget.json).
# OpenSpec needs npm, handled in a separate .ps1 script.
exit 0
{{- end }}

set -euo pipefail
log() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }

# --- .NET 10 SDK -----------------------------------------------------------
if ! command -v dotnet >/dev/null 2>&1 || ! dotnet --list-sdks | grep -q '^10\.'; then
  log "Installing .NET 10 SDK"
{{ if eq .chezmoi.os "darwin" -}}
  brew install --cask dotnet-sdk || {
    log "Cask install failed; falling back to dotnet-install.sh"
    curl -fsSL https://dot.net/v1/dotnet-install.sh | bash -s -- --channel 10.0 --install-dir "$HOME/.dotnet"
    export PATH="$HOME/.dotnet:$PATH"
  }
{{ else -}}
  sudo apt-get install -y dotnet-sdk-10.0 || {
    log "apt install failed; falling back to dotnet-install.sh"
    curl -fsSL https://dot.net/v1/dotnet-install.sh | bash -s -- --channel 10.0 --install-dir "$HOME/.dotnet"
    export PATH="$HOME/.dotnet:$PATH"
  }
{{ end -}}
else
  log ".NET 10 SDK already installed"
fi

# --- Node via fnm ----------------------------------------------------------
if command -v fnm >/dev/null 2>&1; then
  log "Installing latest Node LTS via fnm"
  eval "$(fnm env --use-on-cd --shell bash)"
  fnm install --lts
  fnm default "$(fnm current)"
else
  log "fnm not found; skipping Node install (was it in your Brewfile/apt.txt?)"
fi

# --- Python via uv ---------------------------------------------------------
if command -v uv >/dev/null 2>&1; then
  log "Installing Python 3.12 via uv"
  uv python install 3.12
  uv python pin 3.12 --global 2>/dev/null || true
else
  log "uv not found; skipping Python install"
fi

# --- Claude Code (native installer) ----------------------------------------
if ! command -v claude >/dev/null 2>&1; then
  log "Installing Claude Code CLI"
  curl -fsSL https://claude.ai/install.sh | bash || log "Claude Code install failed; install manually."
fi

# --- OpenSpec (npm) --------------------------------------------------------
if command -v npm >/dev/null 2>&1; then
  log "Installing OpenSpec via npm"
  npm install -g @fission-ai/openspec@latest || log "OpenSpec install failed."
else
  log "npm not on PATH; open a new shell so fnm exports it, then re-run 'chezmoi apply'."
fi

# --- GitHub Copilot CLI (Linux/WSL only — brew handles it on macOS) -------
{{ if ne .chezmoi.os "darwin" -}}
if ! command -v copilot >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
  log "Installing GitHub Copilot CLI via npm"
  npm install -g @github/copilot || log "Copilot CLI install failed."
fi
{{ end -}}

# --- OpenCode (script installer on WSL since brew may not be ideal) -------
{{ if .is_wsl -}}
if ! command -v opencode >/dev/null 2>&1; then
  log "Installing OpenCode via official installer"
  curl -fsSL https://opencode.ai/install | bash || log "OpenCode install failed."
fi
{{ end -}}

log "Runtime install step complete."
