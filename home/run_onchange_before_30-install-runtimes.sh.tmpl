{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash

set -euo pipefail
log() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }

# --- .NET 10 SDK -----------------------------------------------------------
if ! command -v dotnet >/dev/null 2>&1 || ! dotnet --list-sdks | grep -q '^10\.'; then
  log "Installing .NET 10 SDK"
{{ if eq .chezmoi.os "darwin" -}}
  brew install --cask dotnet-sdk || {
    log "Cask install failed; falling back to dotnet-install.sh"
    curl -fsSL https://dot.net/v1/dotnet-install.sh | bash -s -- --channel 10.0 --install-dir "$HOME/.dotnet"
    export PATH="$HOME/.dotnet:$PATH"
  }
{{ else -}}
  sudo apt-get install -y dotnet-sdk-10.0 || {
    log "apt install failed; falling back to dotnet-install.sh"
    curl -fsSL https://dot.net/v1/dotnet-install.sh | bash -s -- --channel 10.0 --install-dir "$HOME/.dotnet"
    export PATH="$HOME/.dotnet:$PATH"
  }
{{ end -}}
else
  log ".NET 10 SDK already installed"
fi

{{ if ne .chezmoi.os "darwin" -}}
# fnm + uv aren't in apt; install into ~/.local/bin (already on PATH via
# dot_zshrc/dot_bashrc). macOS gets them from the Brewfile.
if ! command -v fnm >/dev/null 2>&1; then
  log "Installing fnm"
  curl -fsSL https://fnm.vercel.app/install | bash -s -- --install-dir "$HOME/.local/bin" --skip-shell
  export PATH="$HOME/.local/bin:$PATH"
fi
if ! command -v uv >/dev/null 2>&1; then
  log "Installing uv"
  curl -LsSf https://astral.sh/uv/install.sh | sh
  export PATH="$HOME/.local/bin:$PATH"
fi
{{ end -}}

# --- Node via fnm ----------------------------------------------------------
if command -v fnm >/dev/null 2>&1; then
  log "Installing latest Node LTS via fnm"
  eval "$(fnm env --use-on-cd --shell bash)"
  fnm install --lts
  fnm default "$(fnm current)"
else
  log "fnm not found; skipping Node install (was it in your Brewfile/apt.txt?)"
fi

# --- Python via uv ---------------------------------------------------------
if command -v uv >/dev/null 2>&1; then
  log "Installing Python 3.12 via uv"
  uv python install 3.12
  uv python pin 3.12 --global 2>/dev/null || true
else
  log "uv not found; skipping Python install"
fi

# --- Claude Code (native installer) ----------------------------------------
if ! command -v claude >/dev/null 2>&1; then
  log "Installing Claude Code CLI"
  curl -fsSL https://claude.ai/install.sh | bash || log "Claude Code install failed; install manually."
fi

# --- OpenSpec (npm) --------------------------------------------------------
if command -v npm >/dev/null 2>&1; then
  log "Installing OpenSpec via npm"
  npm install -g @fission-ai/openspec@latest || log "OpenSpec install failed."
else
  log "npm not on PATH; open a new shell so fnm exports it, then re-run 'chezmoi apply'."
fi

# --- GitHub Copilot CLI (Linux/WSL only — brew handles it on macOS) -------
{{ if ne .chezmoi.os "darwin" -}}
if ! command -v copilot >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
  log "Installing GitHub Copilot CLI via npm"
  npm install -g @github/copilot || log "Copilot CLI install failed."
fi
{{ end -}}

# --- OpenCode (script installer on WSL since brew may not be ideal) -------
{{ if .is_wsl -}}
if ! command -v opencode >/dev/null 2>&1; then
  log "Installing OpenCode via official installer"
  curl -fsSL https://opencode.ai/install | bash || log "OpenCode install failed."
fi
{{ end -}}

{{ if ne .chezmoi.os "darwin" -}}
# Azure Functions Core Tools v4 — not reliably in the MS apt feed for new
# Ubuntu releases; npm is codename-independent.
if ! command -v func >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
  log "Installing Azure Functions Core Tools v4 via npm"
  npm install -g azure-functions-core-tools@4 --unsafe-perm true || log "Func Core Tools install failed."
fi

# yazi + lazygit: no apt package on Ubuntu — fetch prebuilt release binaries.
case "$(uname -m)" in
  x86_64)  yt=x86_64-unknown-linux-gnu;  lg=Linux_x86_64 ;;
  aarch64) yt=aarch64-unknown-linux-gnu; lg=Linux_arm64  ;;
  *)       yt=""; lg="" ;;
esac
if [ -n "$lg" ] && ! command -v lazygit >/dev/null 2>&1; then
  log "Installing lazygit"
  v=$(curl -fsSL https://api.github.com/repos/jesseduffield/lazygit/releases/latest | grep -Po '"tag_name": *"v\K[^"]*') || v=""
  if [ -n "$v" ] && curl -fsSL "https://github.com/jesseduffield/lazygit/releases/latest/download/lazygit_${v}_${lg}.tar.gz" -o /tmp/lazygit.tgz; then
    tar -xzf /tmp/lazygit.tgz -C /tmp lazygit && sudo install -m755 /tmp/lazygit /usr/local/bin/lazygit || log "lazygit install failed."
  else
    log "lazygit download failed."
  fi
fi
if [ -n "$yt" ] && ! command -v yazi >/dev/null 2>&1; then
  log "Installing yazi"
  if curl -fsSL "https://github.com/sxyazi/yazi/releases/latest/download/yazi-${yt}.zip" -o /tmp/yazi.zip; then
    unzip -oq /tmp/yazi.zip -d /tmp \
      && sudo install -m755 "/tmp/yazi-${yt}/yazi" /usr/local/bin/yazi \
      && sudo install -m755 "/tmp/yazi-${yt}/ya"   /usr/local/bin/ya \
      || log "yazi install failed."
  else
    log "yazi download failed."
  fi
fi
{{ end -}}

# fzf via official installer into ~/.fzf (OMZ fzf plugin auto-detects it).
if [ ! -d "$HOME/.fzf" ]; then
  log "Installing fzf (~/.fzf)"
  git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf" \
    && "$HOME/.fzf/install" --bin \
    || log "fzf install failed."
fi

log "Runtime install step complete."
{{- end -}}
